<!DOCTYPE html>
<html>
<head>
    <title>Edu Seria Dashboard</title>
    <style>
        body { font-family: sans-serif; margin: 0; padding: 20px; color: #333; }
        .header { border-bottom: 2px solid #333; padding-bottom: 10px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: flex-end; }
        h2, h3, h4 { margin: 0 0 10px 0; }
        .container { display: flex; gap: 20px; }
        .col-main { flex: 2; }
        .col-side { flex: 1; background: #f9f9f9; border: 1px solid #ccc; padding: 15px; height: fit-content; }
        
        .course-box { border: 1px solid #aaa; padding: 15px; margin-bottom: 15px; }
        .actions { margin-top: 15px; padding-top: 10px; border-top: 1px dashed #ccc; }
        
        .btn { padding: 5px 10px; border: 1px solid #333; background: #eee; color: #333; text-decoration: none; cursor: pointer; font-size: 13px; margin-right: 5px; }
        .btn:hover { background: #ddd; }
        
        label { display: block; font-size: 14px; font-weight: bold; margin-bottom: 5px; margin-top: 10px; }
        input, textarea { width: 100%; padding: 8px; border: 1px solid #999; box-sizing: border-box; }
        .btn-submit { width: 100%; padding: 10px; background: #333; color: white; border: none; cursor: pointer; margin-top: 15px; }
        
        .notice { border: 1px solid #d8000c; color: #d8000c; padding: 10px; font-size: 14px; background: #fff; }
    </style>
</head>
<body>

    <div class="header">
        <h2>Edu Seria Management</h2>
        <div>
            User: <strong><%= user.name %></strong> [ <%= user.role %> ] | 
            <a href="/logout">Logout</a>
        </div>
    </div>

    <div class="container">
        <div class="col-main">
            <h4>Available Modules</h4>
            <% courses.forEach(function(course) { %>
                <div class="course-box">
                    <h3><%= course.title %></h3>
                    <p style="margin: 0;"><%= course.description %></p>
                    
                    <% if (user.role === 'Educator') { %>
                        <div class="actions">
                            <a href="/edit-course/<%= course.id %>" class="btn">Edit</a>
                            <form action="/delete-course/<%= course.id %>" method="POST" style="display:inline;">
                                <button type="submit" class="btn" onclick="return confirm('Delete this course?');">Delete</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            <% }); %>
        </div>

        <div class="col-side">
            <% if (user.role === 'Educator') { %>
                <h4>Create New Course</h4>
                <form action="/create-course" method="POST">
                    <label>Title</label>
                    <input type="text" name="title" required>
                    
                    <label>Description</label>
                    <textarea name="description" rows="4" required></textarea>
                    
                    <button type="submit" class="btn-submit">Save Course</button>
                </form>
            <% } else { %>
                <div class="notice">
                    <strong>Read-Only Access:</strong> You are logged in as a Learner. Course modification tools are disabled.
                </div>
            <% } %>
        </div>
    </div>

</body>
</html>