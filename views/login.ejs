<!DOCTYPE html>
<html>
<head>
    <title>Edu Seria LMS</title>
    <style>
        body { font-family: sans-serif; background: #fff; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .login-box { border: 1px solid #ccc; padding: 30px; width: 300px; }
        h2 { margin-top: 0; color: #333; }
        .error { color: #d8000c; margin-bottom: 15px; font-size: 14px; border: 1px solid #d8000c; padding: 5px; }
        label { font-size: 14px; font-weight: bold; }
        input { width: 100%; padding: 8px; margin: 5px 0 15px 0; border: 1px solid #999; box-sizing: border-box; }
        button { width: 100%; padding: 10px; background: #333; color: white; border: none; cursor: pointer; }
        button:hover { background: #555; }
        .hint { font-size: 12px; color: #666; margin-top: 20px; border-top: 1px solid #eee; padding-top: 10px; }
    </style>
</head>
<body>
    <div class="login-box">
        <h2>Edu Seria Login</h2>
        
        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>

        <form action="/login" method="POST">
            <label>Email</label>
            <input type="email" name="email" required>
            
            <label>Password</label>
            <input type="password" name="password" required>
            
            <button type="submit">Log In</button>
        </form>
    </div>
</body>
</html>