<!DOCTYPE html>
<html>
<head>
    <title>Edit Course</title>
    <style>
        body { font-family: sans-serif; padding: 20px; color: #333; display: flex; justify-content: center; }
        .form-box { width: 100%; max-width: 500px; border: 1px solid #ccc; padding: 20px; background: #f9f9f9; }
        h2 { margin-top: 0; border-bottom: 2px solid #333; padding-bottom: 10px; }
        label { display: block; font-size: 14px; font-weight: bold; margin-bottom: 5px; margin-top: 15px; }
        input, textarea { width: 100%; padding: 8px; border: 1px solid #999; box-sizing: border-box; }
        .btn-submit { width: 100%; padding: 10px; background: #333; color: white; border: none; cursor: pointer; margin-top: 20px; }
        .btn-cancel { display: block; margin-top: 15px; text-align: center; color: #666; font-size: 14px; }
    </style>
</head>
<body>

    <div class="form-box">
        <h2>Edit Course Data</h2>
        
        <form action="/update-course/<%= course.id %>" method="POST">
            <label>Title</label>
            <input type="text" name="title" value="<%= course.title %>" required>
            
            <label>Description</label>
            <textarea name="description" rows="6" required><%= course.description %></textarea>
            
            <button type="submit" class="btn-submit">Update Record</button>
        </form>
        
        <a href="/dashboard" class="btn-cancel">Cancel</a>
    </div>

</body>
</html>